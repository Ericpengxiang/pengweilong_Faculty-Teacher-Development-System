.detail-header {
  background: linear-gradient(135deg, #1a3a4a 0%, #2d5a70 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
}
.detail-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  line-height: 1.4;
  margin-bottom: 20rpx;
}
.detail-status {
  display: inline-block;
  padding: 8rpx 24rpx;
  border-radius: 100rpx;
  font-size: 24rpx;
  font-weight: 500;
}
.detail-status-0 { background: rgba(24,144,255,0.3); color: #ffffff; }
.detail-status-1 { background: rgba(82,196,26,0.3); color: #ffffff; }
.detail-status-2 { background: rgba(255,77,79,0.3); color: #ffffff; }
.info-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(26,58,74,0.07);
}
.info-row {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f4f2ee;
}
.info-row:last-child { border-bottom: none; }
.info-key {
  width: 160rpx;
  font-size: 28rpx;
  color: #999999;
  flex-shrink: 0;
}
.info-val {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a1a;
  line-height: 1.5;
}
.dept-tag {
  display: inline-block;
  background: #1a3a4a;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  padding: 6rpx 20rpx;
  border-radius: 100rpx;
  margin-bottom: 8rpx;
}
.dept-hint {
  font-size: 22rpx;
  color: #999999;
}
.actions {
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
}
.actions button {
  flex: 1;
  height: 88rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
}
.actions button::after { border: none; }
.btn-approve {
  background: #52c41a;
  color: #ffffff;
}
.btn-reject {
  background: #ff4d4f;
  color: #ffffff;
}
.btn-edit {
  background: #1a3a4a;
  color: #ffffff;
}
.btn-delete {
  background: #fff2f0;
  color: #ff4d4f;
  border: 2rpx solid #ffccc7;
}
