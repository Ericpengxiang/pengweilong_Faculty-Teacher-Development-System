.filter-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.filter-item {
  flex: 1;
  background: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  color: #1a3a4a;
  text-align: center;
  box-shadow: 0 2rpx 10rpx rgba(26,58,74,0.06);
}
.add-btn {
  margin-bottom: 24rpx;
}
.add-btn button {
  width: 100%;
  height: 88rpx;
  background: #1a3a4a;
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}
.add-btn button::after { border: none; }
.archive-item {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(26,58,74,0.07);
}
.item-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}
.item-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  flex: 1;
  margin-right: 16rpx;
  line-height: 1.4;
}
.status-tag {
  padding: 6rpx 20rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 500;
  white-space: nowrap;
}
.status-0 { background: #e6f7ff; color: #1890ff; }
.status-1 { background: #f6ffed; color: #52c41a; }
.status-2 { background: #fff2f0; color: #ff4d4f; }
.item-meta {
  display: flex;
  gap: 20rpx;
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 12rpx;
}
.meta-type {
  background: rgba(26,58,74,0.08);
  color: #1a3a4a;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}
.item-dept {
  font-size: 22rpx;
  color: #1a3a4a;
  background: rgba(26,58,74,0.06);
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  margin-bottom: 10rpx;
}
.item-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.empty {
  text-align: center;
  padding: 120rpx 0;
  color: #999999;
}
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; }
