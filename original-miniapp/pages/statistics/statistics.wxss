.page-header {
  background: linear-gradient(135deg, #1a3a4a 0%, #2d5a70 100%);
  border-radius: 20rpx;
  padding: 36rpx 40rpx;
  margin-bottom: 24rpx;
}
.page-header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
}
.page-header-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 8rpx;
}
.section-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(26,58,74,0.07);
}
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a3a4a;
  margin-bottom: 28rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #c8a96e;
}
.bar-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.bar-label {
  width: 100rpx;
  font-size: 26rpx;
  color: #666666;
}
.bar-wrap {
  flex: 1;
  height: 28rpx;
  background: #f4f2ee;
  border-radius: 100rpx;
  overflow: hidden;
  margin: 0 16rpx;
}
.bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #1a3a4a, #2d5a70);
  border-radius: 100rpx;
  min-width: 8rpx;
}
.bar-value {
  width: 60rpx;
  text-align: right;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a3a4a;
}
.type-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f4f2ee;
}
.type-item:last-child { border-bottom: none; }
.type-name {
  font-size: 28rpx;
  color: #1a1a1a;
}
.type-count {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a3a4a;
  background: rgba(26,58,74,0.08);
  padding: 6rpx 20rpx;
  border-radius: 100rpx;
}
.rank-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f4f2ee;
}
.rank-item:last-child { border-bottom: none; }
.rank-num {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f4f2ee;
  color: #666666;
  font-size: 26rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  text-align: center;
  line-height: 56rpx;
}
.rank-num-1 { background: #c8a96e; color: #ffffff; }
.rank-num-2 { background: #b0b0b0; color: #ffffff; }
.rank-num-3 { background: #cd7f32; color: #ffffff; }
.rank-name {
  flex: 1;
  font-size: 30rpx;
  color: #1a1a1a;
}
.rank-count {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a3a4a;
}
.empty-tip {
  text-align: center;
  color: #999999;
  padding: 40rpx 0;
  font-size: 26rpx;
}
