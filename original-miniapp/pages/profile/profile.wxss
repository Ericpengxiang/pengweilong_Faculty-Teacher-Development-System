.user-banner {
  background: linear-gradient(135deg, #1a3a4a 0%, #2d5a70 100%);
  border-radius: 20rpx;
  padding: 48rpx 40rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 32rpx;
}
.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: rgba(200,169,110,0.3);
  border: 4rpx solid rgba(200,169,110,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #c8a96e;
  font-weight: bold;
  text-align: center;
  line-height: 112rpx;
}
.user-info { flex: 1; }
.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 10rpx;
}
.user-role {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  background: rgba(255,255,255,0.15);
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 100rpx;
  margin-bottom: 8rpx;
}
.user-username {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
}
.menu-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(26,58,74,0.07);
}
.menu-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 0;
  border-bottom: 2rpx solid #f4f2ee;
}
.menu-row:last-child { border-bottom: none; }
.menu-row-text {
  font-size: 30rpx;
  color: #1a1a1a;
}
.menu-row-arrow {
  font-size: 32rpx;
  color: #cccccc;
}
.logout-btn {
  width: 100%;
  height: 96rpx;
  background: #fff2f0;
  color: #ff4d4f;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: 2rpx solid #ffccc7;
  margin-top: 8rpx;
}
.logout-btn::after { border: none; }
