.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a3a4a;
  margin-bottom: 32rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #c8a96e;
}
.form-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 36rpx;
  box-shadow: 0 4rpx 20rpx rgba(26,58,74,0.07);
}
.form-item { margin-bottom: 36rpx; }
.form-label {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 14rpx;
  display: block;
  font-weight: 500;
}
.form-input {
  background: #f8f7f5;
  border: 2rpx solid #e8e4dc;
  border-radius: 12rpx;
  padding: 26rpx 28rpx;
  font-size: 30rpx;
  color: #1a1a1a;
  width: 100%;
  box-sizing: border-box;
}
.form-picker {
  background: #f8f7f5;
  border: 2rpx solid #e8e4dc;
  border-radius: 12rpx;
  padding: 26rpx 28rpx;
  font-size: 30rpx;
  color: #1a1a1a;
  display: flex;
  justify-content: space-between;
}
.save-btn {
  width: 100%;
  height: 96rpx;
  background: #1a3a4a;
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 48rpx;
  letter-spacing: 4rpx;
}
.save-btn::after { border: none; }
