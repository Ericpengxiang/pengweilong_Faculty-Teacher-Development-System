.welcome {
  background: linear-gradient(135deg, #1a3a4a 0%, #2d5a70 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
}
.welcome-top {
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.welcome-logo {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  flex-shrink: 0;
  border: 3rpx solid rgba(200,169,110,0.5);
}
.welcome-info {
  flex: 1;
}
.welcome-school {
  font-size: 22rpx;
  color: rgba(200,169,110,0.9);
  letter-spacing: 2rpx;
  margin-bottom: 6rpx;
}
.welcome-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 8rpx;
}
.welcome-role {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  background: rgba(255,255,255,0.15);
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 100rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a3a4a;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #c8a96e;
}
.menu-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 24rpx;
}
.menu-item {
  flex: 1;
  min-width: 200rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 36rpx 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(26,58,74,0.08);
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}
.menu-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}
.menu-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a3a4a;
  margin-bottom: 8rpx;
}
.menu-desc {
  font-size: 22rpx;
  color: #999999;
  line-height: 1.5;
}
.stat-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}
.stat-card {
  flex: 1;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(26,58,74,0.08);
}
.stat-num {
  font-size: 56rpx;
  font-weight: bold;
  color: #1a3a4a;
}
.stat-label {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}
