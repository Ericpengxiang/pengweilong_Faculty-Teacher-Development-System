<view class="login-page">
  <view class="header">
    <image class="logo-img" src="/images/logo.png" mode="aspectFit" />
    <view class="logo-school">西安培华学院</view>
    <view class="logo-text">教师成长档案管理系统</view>
    <view class="logo-en">Xi'an Peihua University</view>
  </view>

  <view class="form-card">
    <view class="form-title">{{isRegister ? "注册账号" : "欢迎登录"}}</view>
    <view class="form-subtitle">{{isRegister ? "填写信息创建教师账号" : "使用账号密码登录系统"}}</view>

    <view class="input-group">
      <text class="input-label">用户名</text>
      <input class="input-field" placeholder="请输入用户名" value="{{username}}" bindinput="inputUsername" />
    </view>

    <view class="input-group">
      <text class="input-label">密码</text>
      <input class="input-field" type="password" placeholder="请输入密码" value="{{password}}" bindinput="inputPassword" />
    </view>

    <block wx:if="{{isRegister}}">
      <view class="input-group">
        <text class="input-label">姓名</text>
        <input class="input-field" placeholder="请输入真实姓名" value="{{name}}" bindinput="inputName" />
      </view>
      <view class="input-group">
        <text class="input-label">手机号（选填）</text>
        <input class="input-field" type="number" placeholder="请输入手机号" value="{{phone}}" bindinput="inputPhone" />
      </view>
      <view class="input-group">
        <text class="input-label">邮箱（选填）</text>
        <input class="input-field" placeholder="请输入邮箱" value="{{email}}" bindinput="inputEmail" />
      </view>
    </block>

    <button class="submit-btn" bindtap="submit">{{isRegister ? "立即注册" : "登 录"}}</button>
    <view class="switch-link" bindtap="switchMode">
      {{isRegister ? "已有账号？返回登录" : "没有账号？注册新账号"}}
    </view>

    <view class="hint-box" wx:if="{{!isRegister}}">
      <view class="hint-title">测试账号</view>
      <view class="hint-item">管理员：admin / 123456</view>
      <view class="hint-item">教师：teacher001 / 123456</view>
    </view>
  </view>
</view>
