.login-page {
  background: linear-gradient(160deg, #1a3a4a 0%, #2d5a70 60%, #1a3a4a 100%);
  min-height: 100vh;
  padding: 0;
}
.header {
  padding: 80rpx 60rpx 40rpx;
  text-align: center;
}
.logo-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  margin-bottom: 20rpx;
  border: 4rpx solid rgba(200,169,110,0.4);
}
.logo-school {
  font-size: 40rpx;
  font-weight: bold;
  color: #c8a96e;
  letter-spacing: 4rpx;
  margin-bottom: 6rpx;
}
.logo-text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
  letter-spacing: 2rpx;
  margin-bottom: 6rpx;
}
.logo-en {
  font-size: 22rpx;
  color: rgba(255,255,255,0.45);
  letter-spacing: 1rpx;
}
.form-card {
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 48rpx 40rpx 60rpx;
  margin-top: 40rpx;
}
.form-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1a3a4a;
  margin-bottom: 8rpx;
}
.form-subtitle {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 48rpx;
}
.input-group { margin-bottom: 28rpx; }
.input-label {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 12rpx;
  display: block;
  font-weight: 500;
}
.input-field {
  background: #f8f7f5;
  border: 2rpx solid #e8e4dc;
  border-radius: 14rpx;
  padding: 28rpx 32rpx;
  font-size: 30rpx;
  color: #1a1a1a;
  width: 100%;
  box-sizing: border-box;
}
.submit-btn {
  width: 100%;
  height: 96rpx;
  background: #1a3a4a;
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 48rpx;
  letter-spacing: 4rpx;
}
.submit-btn::after { border: none; }
.switch-link {
  text-align: center;
  color: #1a3a4a;
  margin-top: 32rpx;
  font-size: 28rpx;
  font-weight: 500;
}
.hint-box {
  background: rgba(26,58,74,0.06);
  border-radius: 14rpx;
  padding: 24rpx 28rpx;
  margin-top: 40rpx;
  border: 2rpx dashed rgba(26,58,74,0.2);
}
.hint-title {
  font-size: 24rpx;
  color: #666666;
  font-weight: 600;
  margin-bottom: 10rpx;
}
.hint-item {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.8;
}
